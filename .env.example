# WhisperFlow - Configuración
# Copia este archivo a .env y configura tus valores

# OpenAI API Key (para transcripción rápida con Whisper API)
# Obtén tu key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# Modo de transcripción:
# - "openai" = Usa OpenAI API (rápido, requiere API key, $0.006/min)
# - "local" = Usa modelo local (gratis, lento, consume CPU)
TRANSCRIPTION_MODE=openai

# Modelo local a usar si TRANSCRIPTION_MODE=local
# Opciones: tiny, base, small, medium, large
LOCAL_MODEL=small

# Puerto del servidor
PORT=8181
